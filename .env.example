# LLM Configuration
# Set either OPENAI_API_KEY or GOOGLE_API_KEY. The app will detect and use the active key.
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Optional Enrichment & Contact APIs
# If left blank, the app gracefully falls back to BeautifulSoup scraping and simulated demo contacts.
TAVILY_API_KEY=
FIRECRAWL_API_KEY=
APOLLO_API_KEY=

# Optional CRM Integration
# Absolute path to Google Sheets credentials json file if syncing is desired.
GOOGLE_SHEETS_CREDENTIALS=
GOOGLE_SHEETS_SPREADSHEET_ID=

# App Configuration
PORT=8000
DATABASE_URL=sqlite:///gtm_crm.db
LOG_LEVEL=INFO
